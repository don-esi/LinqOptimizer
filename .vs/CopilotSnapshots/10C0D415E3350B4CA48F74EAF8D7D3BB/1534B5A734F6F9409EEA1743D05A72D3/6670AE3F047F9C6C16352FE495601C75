<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <DocumentationFile>bin\$(Configuration)\$(TargetFramework)\LinqOptimizer.FSharp.xml</DocumentationFile>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <Tailcalls>false</Tailcalls>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <Tailcalls>true</Tailcalls>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="AssemblyInfo.fs" />
    <Compile Include="QueryBuilder.fs" />
    <Compile Include="FSharpQuery.fs" />
    <Compile Include="FSharpParallelQuery.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\LinqOptimizer.Base\LinqOptimizer.Base.csproj" />
    <ProjectReference Include="..\LinqOptimizer.Core\LinqOptimizer.Core.fsproj" />
  </ItemGroup>

</Project>
